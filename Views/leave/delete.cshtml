@model AsumbiCampusSystem.Models.LeaveRecord

@{
    ViewData["Title"] = "Delete Leave Record";
}

<div class="container mt-4">
    <h2>Delete Leave Record</h2>

    <div class="alert alert-warning">Are you sure you want to delete this leave record?</div>

    <div class="card p-4 mb-3">
        <p><strong>Student Name:</strong> @Model.StudentName</p>
        <p><strong>Admission Number:</strong> @Model.AdmissionNumber</p>
        <p><strong>Reason:</strong> @Model.Reason</p>
    </div>

    <form method="post" action="/Leave/DeleteConfirmed/@Model.Id">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="/Leave" class="btn btn-secondary">Cancel</a>
    </form>
</div>