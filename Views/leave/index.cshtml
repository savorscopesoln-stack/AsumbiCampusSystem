@model IEnumerable<AsumbiCampusSystem.Models.LeaveRecord>
@{
    ViewData["Title"] = "Leaves Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Leave Records</h2>
        <a href="/Leave/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle"></i> Create Leave
        </a>
    </div>

    <table class="table table-hover table-bordered align-middle text-center">
        <thead class="table-dark">
            <tr>
                <th>Student</th>
                <th>Class</th>
                <th>Reason</th>
                <th>Time Out</th>
                <th>Expected Return</th>
                <th>Actual Return</th>
                <th>Leave Status</th>
                <th>Type</th>
                <th>Gate Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var leave in Model)
            {
                var leaveStatus = leave.Status switch
                {
                    "Pending" => "Pending",
                    "Approved" => (leave.TimeOut <= DateTime.Now && leave.ExpectedReturn >= DateTime.Now) ? "Active" : "Pending",
                    "Completed" => "Completed",
                    _ => "Pending"
                };

                var leaveBadgeClass = leaveStatus switch
                {
                    "Pending" => "bg-warning text-dark",
                    "Active" => "bg-success",
                    "Completed" => "bg-secondary",
                    _ => "bg-dark"
                };

                var gateStatus = leave.GateStatus switch
                {
                    "Left" => "Left",
                    "Rejected" => "Rejected",
                    _ => "-"
                };

                var gateBadgeClass = leave.GateStatus switch
                {
                    "Left" => "bg-success",
                    "Rejected" => "bg-danger",
                    _ => "bg-secondary"
                };
            <tr id="leave-@leave.Id">
                <td>@leave.StudentName</td>
                <td>@leave.ClassName</td>
                <td>@leave.Reason</td>
                <td>@leave.TimeOut.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@leave.ExpectedReturn.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@(leave.ActualReturn.HasValue ? leave.ActualReturn.Value.ToString("yyyy-MM-dd HH:mm") : "-")</td>
                <td><span class="badge @leaveBadgeClass">@leaveStatus</span></td>
                <td>@leave.LeaveType</td>
                <td><span class="badge @gateBadgeClass">@gateStatus</span></td>
                <td>
                    @if(leave.Status == "Pending")
                    {
                        <button class="btn btn-success btn-sm approve-btn" data-id="@leave.Id">Approve</button>
                    }
                    <button class="btn btn-danger btn-sm delete-btn" data-id="@leave.Id">Delete</button>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
$(document).ready(function() {
    // Approve
    $(".approve-btn").click(function() {
        const btn = $(this);
        const id = btn.data("id");

        $.post('/Leave/Approve', { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() })
            .done(function(res) {
                if(res.success){
                    const row = btn.closest("tr");
                    row.find(".badge").first().removeClass().addClass("badge bg-success").text("Active");
                    btn.remove();
                } else {
                    alert(res.message);
                }
            }).fail(function(){ alert("Error approving leave."); });
    });

    // Delete
    $(".delete-btn").click(function() {
        if(!confirm("Are you sure you want to delete this leave?")) return;
        const btn = $(this);
        const id = btn.data("id");

        $.post('/Leave/Delete', { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() })
            .done(function(res){
                if(res.success){
                    btn.closest("tr").remove();
                } else {
                    alert(res.message);
                }
            }).fail(function(){ alert("Error deleting leave."); });
    });
});
</script>