@model AsumbiCampusSystem.Models.LeaveRecord

@{
    ViewData["Title"] = "Edit Leave Record";
}

<div class="container mt-4">
    <h2>Edit Leave Record</h2>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="mb-3">
            <label class="form-label">Student Name</label>
            <input name="StudentName" class="form-control" value="@Model.StudentName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Admission Number</label>
            <input name="AdmissionNumber" class="form-control" value="@Model.AdmissionNumber" />
        </div>

        <div class="mb-3">
            <label class="form-label">Reason</label>
            <input name="Reason" class="form-control" value="@Model.Reason" />
        </div>

        <div class="mb-3">
            <label class="form-label">Time Out</label>
            <input name="TimeOut" class="form-control" type="datetime-local"
                   value="@Model.TimeOut.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="mb-3">
            <label class="form-label">Expected Return</label>
            <input name="ExpectedReturn" class="form-control" type="datetime-local"
                   value="@Model.ExpectedReturn.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="mb-3">
            <label class="form-label">Actual Return</label>
            <input name="ActualReturn" class="form-control" type="datetime-local"
                   value="@Model.ActualReturn?.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <select name="Status" class="form-select">
                @if(Model.Status == "Pending")
                { <option value="Pending" selected>Pending</option> }
                else { <option value="Pending">Pending</option> }

                @if(Model.Status == "Approved")
                { <option value="Approved" selected>Approved</option> }
                else { <option value="Approved">Approved</option> }

                @if(Model.Status == "Closed")
                { <option value="Closed" selected>Closed</option> }
                else { <option value="Closed">Closed</option> }

                @if(Model.Status == "Overdue")
                { <option value="Overdue" selected>Overdue</option> }
                else { <option value="Overdue">Overdue</option> }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Approved By</label>
            <input name="ApprovedBy" class="form-control" value="@Model.ApprovedBy" />
        </div>

        <button type="submit" class="btn btn-success">Save Changes</button>
        <a href="/Leave" class="btn btn-secondary">Back</a>
    </form>
</div>