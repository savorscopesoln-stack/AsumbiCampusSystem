@model AsumbiCampusSystem.Models.LeaveRecord

@{
    ViewData["Title"] = "Create Leave";
}

<h2>Create Leave</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Admission Number</label>
        <input type="text" name="AdmissionNumber" id="admissionInput" class="form-control" placeholder="Enter admission number" required />
    </div>

    <div class="mb-3">
        <label>Student Name</label>
        <input type="text" id="studentName" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label>Class</label>
        <input type="text" id="className" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label>Reason</label>
        <input type="text" name="Reason" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Time Out</label>
        <input type="datetime-local" name="TimeOut" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Expected Return</label>
        <input type="datetime-local" name="ExpectedReturn" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-primary">Create Leave</button>
</form>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(document).ready(function(){
    $("#admissionInput").on("input", function() {
        var admissionNumber = $(this).val().trim();
        if(admissionNumber.length > 0){
            $.getJSON("/Leave/GetStudentByAdmission", { admissionNumber: admissionNumber })
                .done(function(data){
                    if(data){
                        $("#studentName").val(data.fullName);
                        $("#className").val(data.className);
                    } else {
                        $("#studentName").val("Not found");
                        $("#className").val("");
                    }
                })
                .fail(function(){
                    $("#studentName").val("Error");
                    $("#className").val("");
                });
        } else {
            $("#studentName").val("");
            $("#className").val("");
        }
    });
});
</script>