@{
    ViewData["Title"] = "Weekly Report";
}

<div class="container mt-4">
    <h2>Weekly Report</h2>

    <div class="card p-4">
        <form>
            <div class="mb-3">
                <label class="form-label">Week</label>
                <input class="form-control" placeholder="Example: Week 2, March 2026" />
            </div>

            <div class="mb-3">
                <label class="form-label">Summary Report</label>
                <textarea class="form-control" rows="6" placeholder="Write weekly incidents, leave cases, overdue returns, and observations..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Save Report</button>
        </form>
    </div>
</div>