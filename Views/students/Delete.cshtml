@model AsumbiCampusSystem.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">
    <h2>Delete Student</h2>

    <div class="alert alert-warning">
        Are you sure you want to delete this student?
    </div>

    <div class="card p-4 mb-3">
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Full Name:</strong> @Model.FullName</p>
        <p><strong>Admission Number:</strong> @Model.AdmissionNumber</p>
        <p><strong>Class Name:</strong> @Model.ClassName</p>
        <p><strong>Status:</strong> @Model.Status</p>
    </div>

    <form method="post" asp-action="DeleteConfirmed" asp-route-id="@Model.Id">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>