@model AsumbiCampusSystem.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-4">
    <h2>Student Details</h2>

    <div class="card p-4">
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Full Name:</strong> @Model.FullName</p>
        <p><strong>Admission Number:</strong> @Model.AdmissionNumber</p>
        <p><strong>Class Name:</strong> @Model.ClassName</p>
        <p><strong>Parent Phone:</strong> @Model.ParentPhone</p>
        <p><strong>RFID UID:</strong> @Model.RFID_UID</p>
        <p><strong>Status:</strong> @Model.Status</p>
    </div>

    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning mt-3">Edit</a>
    <a asp-action="Index" class="btn btn-secondary mt-3">Back</a>
</div>