@model AsumbiCampusSystem.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<style>
    body {
        background: linear-gradient(120deg, #524c4c, #4B0000);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        background: #fff;
        border-radius: 20px;
        padding: 40px 30px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
        color: #333;
        transition: transform 0.2s ease-in-out;
    }

    .login-card:hover {
        transform: translateY(-5px);
    }

    .login-card h2 {
        text-align: center;
        margin-bottom: 15px;
        color: #4B0000;
        font-weight: bold;
    }

    .login-card p {
        text-align: center;
        color: #000000;
        margin-bottom: 25px;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #aaa;
        padding: 10px 12px;
        margin-bottom: 20px;
        font-size: 1rem;
    }

    .form-control:focus {
        border-color: #4B0000;
        box-shadow: 0 0 5px rgba(75, 0, 0, 0.6);
        outline: none;
    }

    .btn-login {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 12px;
        background-color: #4B0000;
        color: #fff;
        font-weight: bold;
        font-size: 1.1rem;
        transition: all 0.2s ease-in-out;
    }

    .btn-login:hover {
        background-color: #800000;
    }

    .alert-danger {
        border-radius: 10px;
        background-color: #ff4d4d;
        color: #fff;
        padding: 10px 15px;
        margin-bottom: 15px;
        text-align: center;
    }
</style>

<div class="login-card">
    <h2>System Login</h2>
    <p>Login according to your rank</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form method="post" asp-action="Login" asp-controller="Account">
        <input asp-for="Username" placeholder="Username" class="form-control" />
        <input asp-for="Password" type="password" placeholder="Password" class="form-control" />

        <button type="submit" class="btn-login">Login</button>
    </form>
</div>