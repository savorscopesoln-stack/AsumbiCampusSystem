@model AsumbiCampusSystem.Models.StaffMember

@{
    ViewData["Title"] = "Staff Details";
}

<div class="container mt-4">
    <h2>Staff Details</h2>

    <div class="card p-4">
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Name:</strong> @Model.FullName</p>
        <p><strong>Staff Number:</strong> @Model.StaffNumber</p>
        <p><strong>Department:</strong> @Model.Department</p>
        <p><strong>Phone:</strong> @Model.PhoneNumber</p>
        <p><strong>RFID:</strong> @Model.RFID_UID</p>
        <p><strong>Status:</strong> @Model.Status</p>
    </div>

    <a href="/Staff/Edit/@Model.Id" class="btn btn-warning mt-3">Edit</a>
    <a href="/Staff" class="btn btn-secondary mt-3">Back</a>
</div>