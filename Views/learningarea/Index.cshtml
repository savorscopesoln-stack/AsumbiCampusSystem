@model List<AsumbiCampusSystem.Models.LearningArea>
@{
    ViewData["Title"] = "Learning Areas";
    var courseName = ViewBag.CourseName as string;
    var courseId = ViewBag.CourseId;
}

<h2>Learning Areas for @courseName</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<a class="btn btn-primary mb-3" href="@Url.Action("Create", new { courseId })">Add Topic</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Topic Name</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Id</td>
                <td>@t.TopicName</td>
                <td>@t.Description</td>
                <td>
                    <a class="btn btn-sm btn-info" href="@Url.Action("Edit", new { id = t.Id })">Edit</a>
                    <form method="post" action="@Url.Action("Delete", new { id = t.Id })" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this topic?');">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>