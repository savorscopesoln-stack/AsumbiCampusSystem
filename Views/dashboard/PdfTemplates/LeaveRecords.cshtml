@model List<AsumbiCampusSystem.Models.LeaveRecord>
@{
    Layout = null;
}

<html>
<head>
    <meta charset="utf-8"/>
    <title>Leave Records - Asumbi Smart Campus</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; background: #f7f7f7; }
        h2 { text-align: center; color: #800000; margin-bottom: 20px; }
        table { width: 100%; border-collapse: separate; border-spacing: 0 8px; }
        th { background-color: #800000; color: white; padding: 10px; border-radius: 8px; }
        td { padding: 10px; background: #ffffff; border-radius: 8px; }
        tr td:first-child { font-weight: bold; }
    </style>
</head>
<body>
    <h2>Leave Records - Asumbi Smart Campus</h2>
    <table>
        <tr>
            <th>#</th>
            <th>Student Name</th>
            <th>Admission Number</th>
            <th>Class</th>
            <th>Reason</th>
            <th>Time Out</th>
            <th>Expected Return</th>
            <th>Status</th>
        </tr>
        @for (int i = 0; i < Model.Count; i++)
        {
            <tr>
                <td>@(i+1)</td>
                <td>@Model[i].StudentName</td>
                <td>@Model[i].AdmissionNumber</td>
                <td>@Model[i].ClassName</td>
                <td>@Model[i].Reason</td>
                <td>@Model[i].TimeOut</td>
                <td>@Model[i].ExpectedReturn</td>
                <td>@Model[i].Status</td>
            </tr>
        }
    </table>
</body>
</html>