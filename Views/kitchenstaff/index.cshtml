@model IEnumerable<AsumbiCampusSystem.Models.MealRecord>

@{
    ViewData["Title"] = "Kitchen Staff Dashboard";
}

<h2>Kitchen Staff Dashboard</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Student Name</th>
            <th>Meal Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Student.FullName</td>
                <td>@item.Status</td>
                <td>
                    @if(item.Status == "Pending")
                    {
                        <form asp-action="Approve" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-success btn-sm">Serve</button>
                        </form>
                        <form asp-action="Reject" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                    }
                    else
                    {
                        @item.Status
                    }
                </td>
            </tr>
        }
    </tbody>
</table>