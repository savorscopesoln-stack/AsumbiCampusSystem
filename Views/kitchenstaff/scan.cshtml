@{
    ViewData["Title"] = "Kitchen Staff Scan";
    var message = TempData["Message"]?.ToString() ?? "";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        color: white;
    }

    .container-box {
        max-width: 450px;
        margin: auto;
        margin-top: 60px;
    }

    /* ID CARD */
    .id-card {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        text-align: center;
        margin-bottom: 25px;
        transition: 0.3s;
    }

    /* FLASH EFFECT */
    .success-flash {
        background: linear-gradient(135deg, #11998e, #38ef7d) !important;
    }

    .error-flash {
        background: linear-gradient(135deg, #cb2d3e, #ef473a) !important;
    }

    /* RFID AREA */
    .rfid-box {
        border: 2px dashed white;
        border-radius: 15px;
        padding: 25px;
        margin-top: 15px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% { box-shadow: 0 0 5px #00f2fe; }
        50% { box-shadow: 0 0 20px #00f2fe; }
        100% { box-shadow: 0 0 5px #00f2fe; }
    }

    /* INPUTS */
    .form-control, .form-select {
        border-radius: 10px;
    }

    /* BUTTON */
    .btn-scan {
        width: 100%;
        padding: 12px;
        border-radius: 30px;
        background: linear-gradient(45deg, #00c6ff, #0072ff);
        border: none;
        color: white;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-scan:hover {
        transform: scale(1.05);
        box-shadow: 0 0 15px #00c6ff;
    }

    .alert {
        border-radius: 10px;
    }
</style>

<div class="container-box">

    <!-- CARD -->
    <div id="cardBox" class="id-card">
        <h4>🍽 Kitchen Scanner</h4>
        <small>Tap Student Card to Scan</small>

        <div class="rfid-box">
            📡 Place RFID Card Here
        </div>
    </div>

    <!-- FORM -->
    <form id="scanForm" asp-action="Scan" method="post">

        <div class="mb-3">
            <label>RFID UID (Auto or Manual)</label>
            <input id="rfidInput" type="text" name="rfidUID"
                   class="form-control"
                   placeholder="Scan or enter RFID"
                   autofocus required />
        </div>

        <div class="mb-3">
            <label>Meal Type</label>
            <select name="mealType" class="form-select" required>
                <option>Breakfast</option>
                <option>Lunch</option>
                <option>Supper</option>
            </select>
        </div>

        <button type="submit" class="btn-scan">
            🚀 Scan & Serve Meal
        </button>
    </form>

    <!-- MESSAGE -->
    @if(!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-info mt-3 text-center">
            @message
        </div>
    }

</div>

<!-- 🔊 SOUND + ⚡ AUTO + 🎨 FLASH -->
<script>
    const message = "@message".toLowerCase();
    const card = document.getElementById("cardBox");
    const input = document.getElementById("rfidInput");

    // 🔊 SOUND EFFECTS
    function playBeep(type) {
        let audio = new Audio(
            type === "success"
                ? "https://www.soundjay.com/buttons/sounds/button-3.mp3"
                : "https://www.soundjay.com/buttons/sounds/button-10.mp3"
        );
        audio.play();
    }

    // 🎨 FLASH + SOUND
    if (message.includes("served")) {
        card.classList.add("success-flash");
        playBeep("success");
    }
    else if (message.includes("denied")) {
        card.classList.add("error-flash");
        playBeep("error");
    }

    // ⚡ AUTO SUBMIT (for RFID scanners)
    input.addEventListener("input", function () {
        if (this.value.length >= 8) { // adjust if needed
            document.getElementById("scanForm").submit();
        }
    });
</script>