```cshtml
@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>

<title>@ViewData["Title"] - Asumbi Campus System</title>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<style>

:root{
--bg-main:#f4f7fb;
--sidebar1:#0f172a;
--sidebar2:#1e293b;
--accent:#2563eb;
--accent2:#06b6d4;
--text-soft:#64748b;
--card-shadow:0 8px 24px rgba(0,0,0,0.08);
}

body{
margin:0;
font-family:Segoe UI;
background:var(--bg-main);
}

.sidebar{
position:fixed;
left:0;
top:0;
height:100%;
width:250px;
background:linear-gradient(180deg,var(--sidebar1),var(--sidebar2));
padding:20px;
color:white;
animation:slideIn 0.6s ease;
}

.sidebar h3{
font-weight:700;
margin-bottom:25px;
}

.sidebar a{
display:flex;
align-items:center;
gap:10px;
padding:12px 14px;
margin:6px 0;
border-radius:10px;
color:#e2e8f0;
text-decoration:none;
transition:0.25s;
}

.sidebar a:hover{
background:rgba(255,255,255,0.1);
transform:translateX(4px);
}

.main{
margin-left:250px;
padding:25px;
animation:fadeUp 0.6s ease;
}

.topbar{
background:white;
padding:15px 20px;
border-radius:14px;
box-shadow:var(--card-shadow);
margin-bottom:25px;
}

.card{
border:none !important;
border-radius:16px !important;
box-shadow:var(--card-shadow) !important;
}

.btn{
border-radius:10px;
}

.table{
background:white;
border-radius:12px;
overflow:hidden;
box-shadow:var(--card-shadow);
}

.table thead{
background:#0f172a;
color:white;
}

.footer{
margin-top:25px;
font-size:13px;
color:var(--text-soft);
}

@@keyframes slideIn{
from{
opacity:0;
transform:translateX(-30px);
}
to{
opacity:1;
transform:translateX(0);
}
}

@@keyframes fadeUp{
from{
opacity:0;
transform:translateY(20px);
}
to{
opacity:1;
transform:translateY(0);
}
}

</style>
</head>

<body>

<div class="sidebar">

<h3>
<i class="fa-solid fa-building-columns"></i>
ASUMBI
</h3>

<a href="/Home">
<i class="fa-solid fa-house"></i>
Home
</a>

<a href="/Dashboard">
<i class="fa-solid fa-chart-line"></i>
Dashboard
</a>

<a href="/Students">
<i class="fa-solid fa-user-graduate"></i>
Students
</a>

<a href="/Staff">
<i class="fa-solid fa-chalkboard-user"></i>
Staff
</a>

<a href="/Leave">
<i class="fa-solid fa-file-signature"></i>
Leave
</a>

<a href="/Attendance">
<i class="fa-solid fa-clipboard-check"></i>
Attendance
</a>

<a href="/Meals">
<i class="fa-solid fa-utensils"></i>
Meals
</a>

<hr/>

<a href="/Account/Login">
<i class="fa-solid fa-right-to-bracket"></i>
Login
</a>

<a href="/Account/Logout">
<i class="fa-solid fa-right-from-bracket"></i>
Logout
</a>

</div>

<div class="main">

<div class="topbar">

<div class="d-flex justify-content-between align-items-center">

<div>

<h5>@ViewData["Title"]</h5>

<small class="text-muted">
Asumbi Smart Campus Management System
</small>

</div>

<div class="text-end">

<div class="fw-bold">

@(Context.Session.GetString("Username") ?? "Guest")

</div>

<small>

@(Context.Session.GetString("Role") ?? "Not Logged In")

</small>

</div>

</div>

</div>

<div class="container-fluid">

@RenderBody()

</div>

<div class="footer">
© 2026 Asumbi Campus System
</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
```
