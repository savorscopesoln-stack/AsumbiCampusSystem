@{
    ViewData["Title"] = "Gate Staff Scan";
    var message = TempData["Message"]?.ToString() ?? "";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: #f4f6f8; /* soft neutral background */
        font-family: "Segoe UI", sans-serif;
        color: #333;
    }

    .container-box {
        max-width: 420px;
        margin: 60px auto;
    }

    /* ID CARD */
    .id-card {
        background: white;
        border-radius: 15px;
        padding: 25px 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        text-align: center;
        transition: all 0.3s ease-in-out;
    }

    .id-card h4 {
        margin-bottom: 5px;
        color: #0d6efd; /* school primary color */
        font-weight: 600;
    }

    .id-card small {
        color: #6c757d;
        font-size: 0.85rem;
    }

    /* RFID AREA */
    .rfid-box {
        border: 2px dashed #0d6efd;
        border-radius: 12px;
        padding: 25px;
        margin-top: 20px;
        margin-bottom: 20px;
        font-size: 1.2rem;
        color: #0d6efd;
        transition: all 0.3s;
    }

    .rfid-box.success {
        background: #d4edda;
        border-color: #28a745;
        color: #155724;
    }

    .rfid-box.error {
        background: #f8d7da;
        border-color: #dc3545;
        color: #721c24;
    }

    .form-control {
        border-radius: 10px;
    }

    .btn-scan {
        width: 100%;
        padding: 12px;
        border-radius: 30px;
        background: #0d6efd;
        border: none;
        color: white;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s;
    }

    .btn-scan:hover {
        transform: scale(1.05);
        box-shadow: 0 0 15px rgba(13, 110, 253, 0.4);
    }

    .alert {
        border-radius: 10px;
    }
</style>

<div class="container-box">

    <!-- CARD -->
    <div id="cardBox" class="id-card">
        <h4>🚪 Gate Scanner</h4>
        <small>Scan Student Leave Request</small>

        <div id="rfidBox" class="rfid-box">
            📡 Place RFID Card Here
        </div>
    </div>

    <!-- FORM -->
    <form id="scanForm" asp-action="Scan" method="post">
        <div class="mb-3">
            <label>RFID UID (Scan or Manual)</label>
            <input id="rfidInput" type="text" name="rfidUID"
                   class="form-control"
                   placeholder="Scan or enter RFID"
                   autofocus required />
        </div>

        <button type="submit" class="btn-scan">
            🚀 Scan & Verify
        </button>
    </form>

    <!-- MESSAGE -->
    @if(!string.IsNullOrEmpty(message))
    {
        <div class="alert mt-3 text-center @(message.ToLower().Contains("denied") ? "alert-danger" : "alert-success")">
            @message
        </div>
    }

</div>

<script>
    const message = "@message".toLowerCase();
    const card = document.getElementById("cardBox");
    const rfidBox = document.getElementById("rfidBox");
    const input = document.getElementById("rfidInput");

    // 🔊 SOUND
    function playBeep(type) {
        let audio = new Audio(
            type === "success"
                ? "https://www.soundjay.com/buttons/sounds/button-3.mp3"
                : "https://www.soundjay.com/buttons/sounds/button-10.mp3"
        );
        audio.play();
    }

    // 🎨 FLASH EFFECT
    if(message.includes("allowed") || message.includes("served") || message.includes("active")) {
        rfidBox.classList.add("success");
        playBeep("success");
    }
    else if(message.includes("denied") || message.includes("invalid")) {
        rfidBox.classList.add("error");
        playBeep("error");
    }

    // ⚡ AUTO SUBMIT for RFID scanners
    input.addEventListener("input", function () {
        if(this.value.length >= 8){
            document.getElementById("scanForm").submit();
        }
    });
</script>