@model AsumbiCampusSystem.Models.AttendanceRecord

@{
    ViewData["Title"] = "Delete Attendance";
}

<div class="container mt-4">
    <h2>Delete Attendance</h2>

    <div class="alert alert-warning">Are you sure you want to delete this attendance record?</div>

    <div class="card p-4 mb-3">
        <p><strong>Student Name:</strong> @Model.StudentName</p>
        <p><strong>Admission Number:</strong> @Model.AdmissionNumber</p>
        <p><strong>Date:</strong> @Model.Date</p>
    </div>

    <form method="post" action="/Attendance/DeleteConfirmed/@Model.Id">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="/Attendance" class="btn btn-secondary">Cancel</a>
    </form>
</div>