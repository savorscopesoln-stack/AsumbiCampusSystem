@model List<AsumbiCampusSystem.Models.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance";
}

<div class="container mt-4">
    <h2 class="mb-3">Attendance Records</h2>

    <a href="/Attendance/Create" class="btn btn-primary mb-3">Add Attendance</a>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Student Name</th>
                <th>Admission</th>
                <th>Class</th>
                <th>Date</th>
                <th>Status</th>
                <th>Recorded By</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var record in Model)
        {
            <tr>
                <td>@record.Id</td>
                <td>@record.StudentName</td>
                <td>@record.AdmissionNumber</td>
                <td>@record.ClassName</td>
                <td>@record.Date</td>
                <td>@record.Status</td>
                <td>@record.RecordedBy</td>
                <td>
                    <a href="/Attendance/Details/@record.Id" class="btn btn-info btn-sm">Details</a>
                    <a href="/Attendance/Edit/@record.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a href="/Attendance/Delete/@record.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>