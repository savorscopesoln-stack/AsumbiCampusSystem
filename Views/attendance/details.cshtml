@model AsumbiCampusSystem.Models.AttendanceRecord

@{
    ViewData["Title"] = "Attendance Details";
}

<div class="container mt-4">
    <h2>Attendance Details</h2>

    <div class="card p-4">
        <p><strong>Student Name:</strong> @Model.StudentName</p>
        <p><strong>Admission Number:</strong> @Model.AdmissionNumber</p>
        <p><strong>Class Name:</strong> @Model.ClassName</p>
        <p><strong>Date:</strong> @Model.Date</p>
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Recorded By:</strong> @Model.RecordedBy</p>
    </div>

    <a href="/Attendance/Edit/@Model.Id" class="btn btn-warning mt-3">Edit</a>
    <a href="/Attendance" class="btn btn-secondary mt-3">Back</a>
</div>