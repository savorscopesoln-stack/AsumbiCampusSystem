@model AsumbiCampusSystem.Models.MealCard

@{
    ViewData["Title"] = "Edit Meal Card";
}

<h2>Edit Meal Card</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="StudentId">Student</label>
        <select asp-for="StudentId" class="form-control" asp-items="@(new SelectList(ViewBag.Students, "Id", "FullName", Model.StudentId))">
            <option value="">-- Select Student --</option>
        </select>
    </div>

    <div class="form-group">
        <label asp-for="StartDate">Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="EndDate">End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="IsActive">Active</label>
        <input asp-for="IsActive" type="checkbox" />
    </div>

    <div class="form-group">
        <label asp-for="IssuedBy">Issued By</label>
        <input asp-for="IssuedBy" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Remarks">Remarks</label>
        <input asp-for="Remarks" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
</form>

<p>
    <a asp-action="Index">Back to List</a>
</p>