@model AsumbiCampusSystem.Models.MealRecord

@{
    ViewData["Title"] = "Edit Meal Record";
}

<div class="container mt-4">
    <h2>Edit Meal Record</h2>

    <form method="post" action="/Meals/Edit">
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="mb-3">
            <label class="form-label">Student Name</label>
            <input name="StudentName" class="form-control" value="@Model.StudentName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Admission Number</label>
            <input name="AdmissionNumber" class="form-control" value="@Model.AdmissionNumber" />
        </div>

        <div class="mb-3">
            <label class="form-label">Meal Type</label>
            <select name="MealType" class="form-select">
                <option value="Breakfast" selected="@(Model.MealType == "Breakfast")">Breakfast</option>
                <option value="Lunch" selected="@(Model.MealType == "Lunch")">Lunch</option>
                <option value="Supper" selected="@(Model.MealType == "Supper")">Supper</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Date</label>
            <input name="Date" class="form-control" value="@Model.Date" />
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <select name="Status" class="form-select">
                <option value="Served" selected="@(Model.Status == "Served")">Served</option>
                <option value="Denied" selected="@(Model.Status == "Denied")">Denied</option>
            </select>
        </div>

        <button type="submit" class="btn btn-success">Save Changes</button>
        <a href="/Meals" class="btn btn-secondary">Back</a>
    </form>
</div>