@model AsumbiCampusSystem.Models.MealCard
@{
    ViewData["Title"] = "Create Meal Card";
}

<h2>Create Meal Card</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="StudentId" class="form-label">Student</label>
        <select asp-for="StudentId" class="form-select" asp-items="@(new SelectList(ViewBag.Students, "Id", "FullName"))">
            <option value="">-- Select Student --</option>
        </select>
        <span asp-validation-for="StudentId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Valid Days</label>
        <input type="number" name="ValidDays" class="form-control" value="30" />
    </div>

    <div class="mb-3">
        <label class="form-label">Issued By</label>
        <input asp-for="IssuedBy" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Remarks</label>
        <input asp-for="Remarks" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>