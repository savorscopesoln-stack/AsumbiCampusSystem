@model AsumbiCampusSystem.Models.User
@{
    ViewData["Title"] = "Add User";
}

<div class="container mt-4">
    <h2>Add User</h2>

    @if(ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form method="post" asp-action="Create">
        <div class="mb-3">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" type="password" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label"></label>
            <select asp-for="Role" class="form-select">
                <option>Master Admin</option>
                <option>Deputy Admin</option>

                <!-- ✅ ADDED ROLES -->
                <option>Dean of Students</option>
                <option>Teacher On Duty</option>

                <!-- EXISTING ROLES -->
                <option>Class Teacher</option>
                <option>Teacher</option>
                <option>Student</option>
                <option>Kitchen Staff</option>

                <!-- ✅ NEW ROLE -->
                <option>Gate Staff</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="StudentId" class="form-label">Linked Student (optional)</label>
            <select asp-for="StudentId" class="form-select" asp-items="@(new SelectList(ViewBag.Students, "Id", "FullName"))">
                <option value="">-- None --</option>
            </select>
        </div>

        <button type="submit" class="btn btn-success">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>